# events is required, but defaults are ok
events {}

# A http server, listening at port 80
http {
  server {
    listen 80;

    # Requests starting with root (/) are handled
    location / {
      # Dev is different from production: this proxies to the Vite dev server for HMR.
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection 'upgrade';

      # Requests are directed to http://app-dev:5173
      proxy_pass http://app-dev:5173;
    }

    # Requests starting with /api/ are handled
    location /api/ {
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection 'upgrade';

      proxy_pass http://api-dev:3003/api/;  # DO NOT MISS THE TRAILING SLASH!!
    }
  }
}
